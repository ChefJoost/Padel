# ════════════════════════════════════════════════
#  PadelPotje — omgevingsvariabelen
#  Kopieer dit bestand naar .env en vul in.
#  Commit .env NOOIT naar git.
# ════════════════════════════════════════════════

# ── Verplicht in productie ───────────────────────
# Willekeurige string van minimaal 32 tekens.
# Genereer bijv. met: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=vervang-dit-met-een-lange-willekeurige-string

# ── Admin account ────────────────────────────────
# Gebruikersnaam die admin-rechten krijgt bij eerste start (als er nog geen admin is).
# Verander dit naar je eigen gebruikersnaam vóór de eerste registratie.
ADMIN_USERNAME=joosts

# ── Push notificaties (VAPID) ────────────────────
# Worden automatisch gegenereerd bij de eerste serverstart en gelogd in de console.
# Zet ze hier in zodat ze bewaard blijven na een herstart/redeploy.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Data opslag ──────────────────────────────────
# Map waar de SQLite-databases worden opgeslagen.
# Op Railway: koppel een persistent volume en stel dit pad in.
DATA_DIR=./data

# ── Server ───────────────────────────────────────
PORT=3000
